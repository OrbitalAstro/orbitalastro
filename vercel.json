{
  "version": 2,
  "buildCommand": "echo 'Skipping build for API-only deployment'",
  "installCommand": "echo 'Skipping install for API-only deployment'",
  "outputDirectory": null,
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.9"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/$1"
    }
  ]
}
