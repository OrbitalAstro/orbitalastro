# Copier ce fichier vers .env puis renseigner les valeurs.
# Le backend charge automatiquement .env au démarrage (voir main.py).

# --- Google Gemini (obligatoire pour /ai/interpret : dialogues, lecture 2026, chat)
# Créer une clé : https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optionnel : si la clé API est restreinte par "référent HTTP" dans Google Cloud,
# indique l’URL autorisée (ex. ton site en prod ou le front local).
# Exemple en local avec Next sur le port 3000 :
# GEMINI_REFERER=http://localhost:3000/

# Optionnel : port du serveur FastAPI (défaut 8000)
# PORT=8000
